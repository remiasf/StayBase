// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  LANDLORD
  SUPER_ADMIN 
}

enum BookingStatus {
  PENDING
  APPROVED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {  
  PENDING
  SUCCESS
  FAILED
}

model User {
  id String @id @default(uuid())
  name String
  login String @unique
  password String
  email String @unique
  bio String?
  avatarUrl String?
  role Role @default(USER)  

  apartments Apartment[]
  bookings Booking[]
}

model Apartment {
  id String @id @default(uuid())
  title String
  description String
  images String[] @default([])
  city String
  address String
  latitude Float
  longitude Float

  price Int
  discountPrice Int?

  size Float
  rooms Int
  maxGuests Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bookings Booking[]

  amenities Amenity[]
}

model Amenity {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  apartments Apartment[]
}

model Booking {
  id String @id @default(uuid())
  
  dailyPrice Int
  totalPrice Int

  status BookingStatus @default(PENDING)
  payments Payment[]

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  startDate DateTime
  endDate DateTime
  updatedAt DateTime @updatedAt
  
  apartmentId String
  apartment Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model Payment {
  id                String        @id @default(uuid())

  bookingId         String
  booking           Booking       @relation(fields: [bookingId], references: [id])

  amount            Decimal       
  currency          String        @default("UAH")

  status            PaymentStatus @default(PENDING)
  provider          String        @default("LIQPAY") 

  providerPaymentId String?       

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

